{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "declaration": true,
        "outDir": "dist/esm",
        "rootDir": "src",
        "types": ["bun"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "__tests__"]
}
