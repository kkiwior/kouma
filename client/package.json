{
    "name": "kouma-client",
    "version": "1.0.0",
    "description": "Kouma visual regression testing client — CLI & library",
    "homepage": "https://github.com/kkiwior/kouma",
    "keywords": [
        "api-client",
        "cli",
        "kouma",
        "playwright",
        "screenshot",
        "testing",
        "visual-regression"
    ],
    "license": "MIT",
    "author": "Kouma Contributors",
    "bin": {
        "kouma": "dist/esm/cli.js"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "main": "dist/cjs/index.js",
    "module": "dist/esm/index.js",
    "types": "dist/esm/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/esm/index.d.ts",
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js"
        },
        "./cypress": {
            "types": "./dist/esm/cypress.d.ts",
            "import": "./dist/esm/cypress.js",
            "require": "./dist/cjs/cypress.js"
        },
        "./playwright": {
            "types": "./dist/esm/playwright.d.ts",
            "import": "./dist/esm/playwright.js",
            "require": "./dist/cjs/playwright.js"
        }
    },
    "scripts": {
        "build": "npm run build:esm && npm run build:cjs && npm run build:cjs-package",
        "build:esm": "tsc -p tsconfig.json",
        "build:cjs": "tsc -p tsconfig.cjs.json",
        "build:cjs-package": "echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
        "test": "bun test",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "devDependencies": {
        "@types/bun": "^1.3.10",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
