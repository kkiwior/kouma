{
    "name": "kouma-dashboard",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev:frontend": "bunx --bun vite",
        "dev:backend": "bun backend/server.ts",
        "lint": "oxlint .",
        "build": "bunx --bun vite build",
        "start": "bun backend/server.ts",
        "test": "find backend frontend/src -name '*.test.ts' -o -name '*.spec.ts' | while IFS= read -r f; do echo \"--- $f ---\" && bun test \"$f\" || exit 1; done",
        "typecheck": "bunx --bun tsc --noEmit"
    },
    "dependencies": {
        "@vueuse/core": "^14.2.1",
        "check-disk-space": "^3.4.0",
        "crypto-js": "^4.2.0",
        "gifuct-js": "^2.1.2",
        "http-status-codes": "^2.3.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.3.0",
        "mongoose-paginate-v2": "^1.9.1",
        "swagger-jsdoc": "^6.2.8",
        "vue": "^3.5.30",
        "vue-router": "^4.6.4"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.1",
        "@types/bun": "^1.3.10",
        "@types/crypto-js": "^4.2.2",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/swagger-jsdoc": "^6.0.4",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vue/tsconfig": "^0.9.0",
        "bun-types": "^1.3.10",
        "jsdom": "^28.1.0",
        "swagger-cli": "^4.0.4",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.9.3",
        "vite": "^7.0.0",
        "vue-tsc": "^3.2.5"
    }
}
